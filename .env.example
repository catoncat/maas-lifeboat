MAAS_API_KEY=replace-with-provider-key
MAAS_GATEWAY_API_KEY=local-test-key
MAAS_PROXY_URL=
MAAS_CONTEXT_WINDOW=500000
MAAS_MAX_TOKENS=131072
# Optional model fallback. Disabled by default because fallback models may have
# smaller context windows or different thinking-token support.
MAAS_MODEL_FALLBACKS=
MAAS_MODEL_FALLBACK_ATTEMPTS=0
MAAS_MODEL_FALLBACK_CONTEXT_WINDOW=128000
MAAS_MODEL_FALLBACK_MAX_TOKENS=32768
MAAS_MODEL_FALLBACK_CONTEXT_SAFETY_TOKENS=4096
MAAS_MODEL_FALLBACK_STRIP_THINKING=1
MAAS_GATEWAY_LOG=logs/gateway_requests.jsonl
MAAS_SAME_RETRY_DELAY_S=0.8
MAAS_ALT_RETRY_DELAY_S=1.2
MAAS_RETRY_BACKOFF_MULTIPLIER=1.5
MAAS_MAX_RETRY_DELAY_S=3.0
MAAS_RETRY_JITTER_S=0.25
MAAS_BUSY_COOLDOWN_S=1.0
MAAS_ALL_BUSY_RETRY_AFTER_S=3
MAAS_ALL_BUSY_RECOVERY_ATTEMPTS=2
MAAS_ALL_BUSY_RECOVERY_DELAY_S=3.0
MAAS_TIMEOUT_S=45
MAAS_STREAM_FIRST_CHUNK_TIMEOUT_S=20
MAAS_GATEWAY_HOST=127.0.0.1
MAAS_GATEWAY_PORT=18788
# For streaming requests this limits only the pre-first-chunk acceptance/retry
# window; after the first chunk arrives, the queue permit is released.
MAAS_MAX_INFLIGHT_REQUESTS=1
MAAS_MAX_BACKEND_ATTEMPTS=5
MAAS_ENABLE_CROSS_INTERFACE_FALLBACK=1
